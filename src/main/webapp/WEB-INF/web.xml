<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

  <servlet>
    <servlet-name>BookAppointment</servlet-name>
    <servlet-class>com.appointment.servlet.BookAppointmentServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>BookAppointment</servlet-name>
    <url-pattern>/book</url-pattern>
  </servlet-mapping>

  <servlet>
  <servlet-name>Login</servlet-name>
  <servlet-class>com.appointment.servlet.LoginServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>Login</servlet-name>
  <url-pattern>/login</url-pattern>
</servlet-mapping>

<servlet>
  <servlet-name>Signup</servlet-name>
  <servlet-class>com.appointment.servlet.SignupServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>Signup</servlet-name>
  <url-pattern>/signup</url-pattern>
</servlet-mapping>

<servlet>
  <servlet-name>Logout</servlet-name>
  <servlet-class>com.appointment.servlet.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>Logout</servlet-name>
  <url-pattern>/logout</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>CancelAppointment</servlet-name>
    <servlet-class>com.appointment.servlet.CancelAppointmentServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CancelAppointment</servlet-name>
    <url-pattern>/cancel</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>CompleteAppointment</servlet-name>
    <servlet-class>com.appointment.servlet.CompleteAppointmentServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CompleteAppointment</servlet-name>
    <url-pattern>/complete</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AddDoctorServlet</servlet-name>
    <servlet-class>com.appointment.servlet.AddDoctorServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddDoctorServlet</servlet-name>
    <url-pattern>/addDoctor</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeleteDoctorServlet</servlet-name>
    <servlet-class>com.appointment.servlet.DeleteDoctorServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteDoctorServlet</servlet-name>
    <url-pattern>/deleteDoctor</url-pattern>
</servlet-mapping>

</web-app>